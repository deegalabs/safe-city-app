# ── SUPABASE ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── DATABASE ───────────────────────────────────────────────────
# Opção A: Supabase (recomendado) — ver ENV.md na raiz
#   DATABASE_URL = URL do pooler (porta 6543) + ?pgbouncer=true no final
#   DIRECT_URL   = conexão direta (porta 5432), sem pgbouncer
# Opção B: Postgres local — docker compose up -d postgres, depois:
#   DATABASE_URL=postgresql://shield:shield@localhost:5432/shield
#   DIRECT_URL=postgresql://shield:shield@localhost:5432/shield
DATABASE_URL=
DIRECT_URL=

# ── REDIS (obrigatório para a API) ──────────────────────────────
# Com Docker: docker compose up -d → redis em localhost:6379
REDIS_URL=redis://localhost:6379

# ── ANTHROPIC ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── WEB PUSH ──────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# ── WHATSAPP (Evolution API) ──────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=safe-city-floripa
WHATSAPP_WEBHOOK_SECRET=

# ── API ───────────────────────────────────────────────────────
API_PORT=3000
# Em dev: inclui localhost:5173 (web) e localhost:5174 (admin)
# Em prod: substitua pelas URLs reais de cada app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
NODE_ENV=development
FINGERPRINT_SALT=

# ── FRONTEND — prefixo VITE_ obrigatório ─────────────────────
# Dev: vazio (proxy Vite). Prod: URL da API sem /api (ex: https://sua-api.railway.app)
VITE_API_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_VAPID_PUBLIC_KEY=
